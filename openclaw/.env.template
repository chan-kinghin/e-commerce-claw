# =============================================================================
# OpenClaw Cross-Border E-Commerce AI Platform - Environment Variables
# =============================================================================
#
# Copy this file to .env and fill in the values:
#   cp .env.template .env
#
# Then source it before running the platform:
#   source .env
#
# Variables marked [REQUIRED] must be set for core functionality.
# Variables marked [OPTIONAL] enhance capabilities but are not blocking.
# Variables marked [PRODUCTION] are needed for production deployment.
# =============================================================================


# =============================================================================
# WEB SCRAPING APIs
# =============================================================================

# [REQUIRED] Decodo - structured web scraping (Amazon, Reddit, YouTube)
# Used by: voc-analyst, geo-optimizer, reddit-spec
# Get token: https://dashboard.decodo.com/
DECODO_AUTH_TOKEN=

# [REQUIRED] Brave Search - high-quality overseas web search
# Used by: voc-analyst, geo-optimizer, reddit-spec
# Get key: https://api.search.brave.com/
BRAVE_API_KEY=

# [REQUIRED] Apify - industrial-grade cloud scraping (Google Maps, TikTok, Instagram)
# Used by: voc-analyst
# Get token: https://console.apify.com/account/integrations
APIFY_TOKEN=


# =============================================================================
# SEARCH ENGINES (OPTIONAL - enhance discovery capabilities)
# =============================================================================

# [OPTIONAL] Tavily - China-domestic direct connection, no VPN needed
# Used by: voc-analyst, geo-optimizer, reddit-spec
# Get key: https://tavily.com/
TAVILY_API_KEY=

# [OPTIONAL] Exa - intent-based semantic search
# Used by: voc-analyst, geo-optimizer, reddit-spec
# Get key: https://exa.ai/
EXA_API_KEY=

# [OPTIONAL] Firecrawl - remote sandbox browser (500 free requests/month)
# Used by: voc-analyst, geo-optimizer
# Get key: https://firecrawl.dev/
FIRECRAWL_API_KEY=


# =============================================================================
# FEISHU (LARK) - Human Interface
# =============================================================================

# [PRODUCTION] Lead Agent Feishu App
# The lead agent is the sole human interface via Feishu
# Create app: https://open.feishu.cn/app
FEISHU_LEAD_APP_ID=
FEISHU_LEAD_APP_SECRET=

# [PRODUCTION] GEO Optimizer Feishu App
FEISHU_GEO_APP_ID=
FEISHU_GEO_APP_SECRET=

# [PRODUCTION] Reddit Specialist Feishu App
FEISHU_REDDIT_APP_ID=
FEISHU_REDDIT_APP_SECRET=

# [PRODUCTION] TikTok Director Feishu App
FEISHU_TIKTOK_APP_ID=
FEISHU_TIKTOK_APP_SECRET=


# =============================================================================
# WEBHOOK ENDPOINTS (Price Monitoring Alerts)
# =============================================================================

# [PRODUCTION] Feishu Incoming Webhook - receives price change alerts
# Create: Feishu group settings -> Bots -> Custom Bot -> Webhook URL
FEISHU_WEBHOOK_URL=

# [OPTIONAL] Telegram Bot - alternative alert channel
# Create: https://t.me/BotFather
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=


# =============================================================================
# REDDIT ACCOUNTS (Reddit Specialist Agent)
# =============================================================================
# Each account uses OAuth tokens. Store refresh tokens here.
# DO NOT commit this file with real tokens.
#
# Token format: Reddit OAuth2 refresh token
# Obtain via: https://www.reddit.com/prefs/apps/ (create script app)

# [PRODUCTION] Reddit Account 001
REDDIT_ACC_001_TOKEN=
REDDIT_ACC_001_SECRET=
REDDIT_ACC_001_USERNAME=

# [PRODUCTION] Reddit Account 002
REDDIT_ACC_002_TOKEN=
REDDIT_ACC_002_SECRET=
REDDIT_ACC_002_USERNAME=

# [PRODUCTION] Reddit Account 003
REDDIT_ACC_003_TOKEN=
REDDIT_ACC_003_SECRET=
REDDIT_ACC_003_USERNAME=

# Uncomment and add more accounts as needed:
# REDDIT_ACC_004_TOKEN=
# REDDIT_ACC_004_SECRET=
# REDDIT_ACC_004_USERNAME=
# REDDIT_ACC_005_TOKEN=
# REDDIT_ACC_005_SECRET=
# REDDIT_ACC_005_USERNAME=


# =============================================================================
# VIDEO GENERATION (TikTok Director Agent)
# =============================================================================

# [OPTIONAL] Volcengine API - for Seedance video generation and VLM analysis
# Used by: tiktok-director (seedance-video, volcengine-video-understanding)
# Uses Coding Plan credits by default; set key only if using direct API
VOLCENGINE_API_KEY=

# [OPTIONAL] Google API Key - for nano-banana-pro image generation
# Used by: tiktok-director
GOOGLE_API_KEY=


# =============================================================================
# AI MODEL PROVIDERS
# =============================================================================

# [REQUIRED] Volcengine (ByteDance) - for doubao-seed-2.0-code models
# Used by: lead, geo-optimizer, tiktok-director
VOLCENGINE_MODEL_API_KEY=

# [REQUIRED] Moonshot AI - for Kimi K2.5 models
# Used by: voc-analyst, reddit-spec
MOONSHOT_API_KEY=
